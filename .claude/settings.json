{
  "permissions": {
    "allow": [
      "Bash(*)",
      "Bash(pkill -f \"watcher/watch-fifa.py\")",
      "Bash(pkill -f \"watcher/fifa_progress.py\")",
      "Bash(pkill -9 -f \"watcher/fifa_progress.py\")",
      "Bash(touch /tmp/fifa-copa-stop)",
      "Bash(nohup bash watcher/run-window.sh)",
      "WebFetch(domain:givevoicetofootball.github.io)",
      "Bash(pkill -f \"sleep 300\")",
      "Bash(ps -eo pid,args)",
      "Bash(git prune *)",
      "Bash(git gc *)",
      "Bash(git fsck *)",
      "WebFetch(domain:www.fifa.com)",
      "Bash(.venv/bin/python -c ' *)",
      "Bash(.venv/bin/fifa-analytics fifa-coletar *)",
      "Bash(export DATABASE_URL=\"sqlite:///./dev.db\")",
      "Bash(export JWT_SECRET_KEY=\"copa2026-dev-secret-change-in-prod\")",
      "Bash(export ADMIN_USERNAME=\"admin\")",
      "Bash(export ADMIN_PASSWORD=\"copa2026\")",
      "Bash(export ADMIN_NAME=\"Admin\")",
      "Bash(npm run *)",
      "Bash(curl -s \"http://localhost:8000/analytics/snapshots/teams\")",
      "Bash(.venv/bin/python -c \"import sys,json; d=json.load\\(sys.stdin\\); print\\('linhas:', len\\(d\\)\\); print\\('snapshots:', sorted\\(set\\(r['snapshot_jogo'] for r in d\\)\\)[-3:], '... max', max\\(r['snapshot_jogo'] for r in d\\)\\)\")",
      "Bash(curl -s -o /dev/null -w \"HTTP:%{http_code}\\\\n\" \"http://localhost:8000/analytics/snapshots/players\")",
      "Bash(curl -s \"http://localhost:8000/matches?status=finalizado\")",
      "Bash(.venv/bin/python -c \"import sys,json; print\\('finalizados via API:', len\\(json.load\\(sys.stdin\\)\\)\\)\")",
      "Bash(DATABASE_URL=\"sqlite:///./dev.db\" .venv/bin/alembic heads)",
      "Bash(DATABASE_URL=\"sqlite:///./dev.db\" .venv/bin/alembic current)",
      "Bash(export DATABASE_URL=\"postgresql+psycopg2://fifa:fifa@localhost:5432/fifa\")",
      "Bash(.venv/bin/alembic upgrade *)",
      "Bash(export ADMIN_USERNAME=\"admin\" ADMIN_PASSWORD=\"copa2026\" ADMIN_NAME=\"Admin\")",
      "Bash(export CORS_ORIGINS=\"http://localhost:3000\")",
      "Bash(.venv/bin/uvicorn api.app.main:app --host 0.0.0.0 --port 8000 --reload)",
      "Bash(npx tsc *)",
      "Bash(.venv/bin/pytest tests/test_platform_api.py tests/test_scoring_engine.py -q)",
      "Bash(curl -s -o /dev/null -w \"/bolao:%{http_code}\\\\n\" http://localhost:3000/bolao)"
    ],
    "deny": [
      "Bash(git push --force:*)",
      "Bash(dd:*)",
      "Bash(shred:*)"
    ],
    "ask": [
      "Bash(rm:*)",
      "Bash(rmdir:*)",
      "Bash(git push:*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "[ -f \".claude/index-hook.py\" ] && python .claude/index-hook.py || exit 0",
            "timeout": 10,
            "statusMessage": "Atualizando índice do vault..."
          },
          {
            "type": "command",
            "command": "f=$(python -c \"import sys,json; d=json.load(sys.stdin); print(d['tool_input'].get('file_path',''))\" 2>/dev/null); echo \"$f\" | grep -qE '\\.claude/commands/.*\\.md$' || exit 0; [ -f \".claude/update-claude-md.py\" ] && python .claude/update-claude-md.py",
            "timeout": 10,
            "statusMessage": "Atualizando tabela de skills no CLAUDE.md..."
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "[ -f \".claude/index-hook.py\" ] && python .claude/index-hook.py || exit 0",
            "timeout": 10,
            "statusMessage": "Atualizando índice do vault..."
          }
        ]
      }
    ]
  }
}
