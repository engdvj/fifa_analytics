# Conexão do Postgres (api + alembic). Copie para .env e ajuste.
DATABASE_URL=postgresql+psycopg2://fifa:fifa@localhost:5432/fifa

# Credenciais usadas pelo serviço db do docker-compose.
POSTGRES_USER=fifa
POSTGRES_PASSWORD=fifa
POSTGRES_DB=fifa

# Segredo do JWT (auth da API). Troque em produção.
JWT_SECRET_KEY=dev-secret-mude-em-prod

# Admin inicial: se setados, o app cria/garante esse usuário como admin no
# startup (seed_admin). Login é por USERNAME. Sem eles, nenhum admin é criado.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=troque-esta-senha
ADMIN_NAME=Admin
